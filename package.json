{
  "name": "script-manage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "dev:electron": "wait-on tcp:5174 && electron .",
    "electron": "electron .",
    "icons:generate": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "build": "vue-tsc -b && vite build",
    "pack:win": "pnpm run build && electron-builder --win nsis",
    "pack:mac": "pnpm run build && electron-builder --mac dmg",
    "pack:linux": "pnpm run build && electron-builder --linux AppImage",
    "pack:all": "pnpm run build && electron-builder -mwl",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@tailwindcss/vite": "^4.2.2",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "com.script.manage",
    "productName": "Script Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icons/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icons/512x512.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
